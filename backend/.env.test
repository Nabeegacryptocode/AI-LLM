# API Settings
API_KEY=your_secure_api_key_here_change_this
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","https://your-wordpress-site.com"]

# LLM Settings
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
MAX_TOKENS=1000

# Embedding Settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Vector DB Settings (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=ibm-docs

# Redis Settings
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# RAG Settings
TOP_K_RESULTS=5
CHUNK_SIZE=800
CHUNK_OVERLAP=200
MIN_RELEVANCE_SCORE=0.7

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/ibm_docs_llm

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Environment
ENVIRONMENT=development