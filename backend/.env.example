# API Settings
API_KEY=your_secure_api_key_here_change_this
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","https://your-wordpress-site.com"]

# LLM Settings
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
MAX_TOKENS=1000

# Embedding Settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Vector DB Settings (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=ibm-docs

# Redis Settings
REDIS_HOST=clarion-ivoryish-dinner-46309.db.redis.io
REDIS_PORT=16235
REDIS_PASSWORD=5GYPmAnDL6SmUQ66XB5MRu7hIKV3ObUJ
REDIS_USER=default
REDIS_URL=redis://default:5GYPmAnDL6SmUQ66XB5MRu7hIKV3ObUJ@clarion-ivoryish-dinner-46309.db.redis.io:16235
CACHE_TTL=3600
REDIS_ENABLED=true

# RAG Settings
TOP_K_RESULTS=5
CHUNK_SIZE=800
CHUNK_OVERLAP=200
MIN_RELEVANCE_SCORE=0.7

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/ibm_docs_llm

# Web Search Settings
WEB_SEARCH_ENABLED=true

# Google Discovery Engine Settings
GOOGLE_PROJECT_ID=71522359792
GOOGLE_DISCOVERY_LOCATION=global
GOOGLE_DISCOVERY_COLLECTION_ID=default_collection
GOOGLE_DISCOVERY_ENGINE_ID=fahmllmdiscoveryengine_1779465166335
GOOGLE_DISCOVERY_SERVING_CONFIG=default_search
USE_DISCOVERY_ENGINE=true
GOOGLE_DISCOVERY_MAX_EXTRACTIVE_ANSWERS=1

# Google Cloud Authentication
# For local development: Set path to your service account JSON file
# Example: GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account-key.json
# For Cloud Run deployment: Set GOOGLE_APPLICATION_CREDENTIALS_JSON environment variable with the JSON content
# For local dev with gcloud CLI: Leave empty (will use gcloud auth)
GOOGLE_APPLICATION_CREDENTIALS=

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Environment
ENVIRONMENT=development