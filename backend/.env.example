# API Settings
API_KEY=your_secure_api_key_here_change_this
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","https://your-wordpress-site.com"]

# LLM Settings
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.7
MAX_TOKENS=1000

# Embedding Settings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Vector DB Settings (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX_NAME=ibm-docs

# Redis Settings
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# RAG Settings
TOP_K_RESULTS=5
CHUNK_SIZE=800
CHUNK_OVERLAP=200
MIN_RELEVANCE_SCORE=0.7

# Database Settings
DATABASE_URL=postgresql://user:password@localhost:5432/ibm_docs_llm

# Web Search Settings
WEB_SEARCH_ENABLED=true

# Google Discovery Engine Settings
GOOGLE_PROJECT_ID=783867443498
GOOGLE_DISCOVERY_LOCATION=global
GOOGLE_DISCOVERY_COLLECTION_ID=default_collection
GOOGLE_DISCOVERY_ENGINE_ID=fahm-llm_1779380839747
GOOGLE_DISCOVERY_SERVING_CONFIG=default_search
USE_DISCOVERY_ENGINE=true

# Google Cloud Authentication (for production deployment)
# Set this to the path of your service account JSON key file
# For Render: Upload the JSON file and set this to the file path
# For local dev with gcloud: Leave empty (will use gcloud auth)
GOOGLE_APPLICATION_CREDENTIALS=

# Logging
LOG_LEVEL=INFO
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Environment
ENVIRONMENT=development